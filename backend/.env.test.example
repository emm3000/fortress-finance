# Testing environment (backend)
# Copy this file to .env.test and adjust values for your environment.
# cp .env.test.example .env.test

DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@localhost:5433/jaa_finanzas_test"
TEST_DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@localhost:5433/jaa_finanzas_test"
JWT_SECRET="CHANGE_ME_to_a_random_string_of_at_least_32_characters"
PORT=4000
NODE_ENV=test
SENTRY_DSN=""

# Avoid side effects during local tests
ENABLE_CRON=false
CORS_ORIGINS=""

# Optional hardening: fail if DATABASE_URL does not look like a test DB
STRICT_TEST_DB=false
