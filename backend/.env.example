# Environment Variables — Personal Finance Backend
# Copy this file to .env and fill with real values
# cp .env.example .env

# ── Database ─────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@localhost:5433/jaa_finanzas"
# Direct connection for Prisma Migrate (without pooler)
DIRECT_URL="postgresql://<DB_USER>:<DB_PASSWORD>@localhost:5433/jaa_finanzas"
# Dedicated database for tests (never point to development/production)
TEST_DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@localhost:5433/jaa_finanzas_test"

# ── JWT Authentication ───────────────────────────────────────
# Minimum 32 characters. Generate a secure one with: openssl rand -base64 48
JWT_SECRET="CHANGE_ME_to_a_random_string_of_at_least_32_characters"

# ── Server ───────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
SENTRY_DSN=""

# Allowed CORS origins (comma-separated)
# Example: CORS_ORIGINS="http://localhost:8081,http://localhost:3000"
CORS_ORIGINS=""

# Enable cron jobs in this instance (true/false)
ENABLE_CRON=false

# Testing-only: fail if DATABASE_URL does not look like a test database
STRICT_TEST_DB=false
