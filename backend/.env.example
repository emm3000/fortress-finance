# Variables de Entorno — Backend Finanzas Personales
# Copia este archivo a .env y rellena los valores reales
# cp .env.example .env

# ── Base de Datos ─────────────────────────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@localhost:5433/jaa_finanzas"
# Base dedicada para tests (nunca apuntar a producción/desarrollo)
TEST_DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@localhost:5433/jaa_finanzas_test"

# ── Autenticación JWT ─────────────────────────────────────────
# Mínimo 32 caracteres. Genera uno seguro con: openssl rand -base64 48
JWT_SECRET="CHANGE_ME_to_a_random_string_of_at_least_32_characters"

# ── Servidor ──────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# Orígenes permitidos para CORS (separados por coma)
# Ejemplo: CORS_ORIGINS="http://localhost:8081,http://localhost:3000"
CORS_ORIGINS=""

# Habilitar cron jobs en esta instancia (true/false)
ENABLE_CRON=false
