// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enum for transaction / category type — enforced at DB level
enum TransactionType {
  INCOME
  EXPENSE
}

model User {
  id            String            @id @default(uuid()) @db.Uuid
  email         String            @unique
  passwordHash  String            @map("password_hash")
  name          String
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  transactions  Transaction[]
  castleState   CastleState?
  budgets       Budget[]
  gameEvents    GameEventLog[]
  wallet        UserWallet?
  inventory     UserInventory[]
  pushTokens    UserPushToken[]
  notifications NotificationLog[]

  @@map("users")
}

model Category {
  id           String          @id @default(uuid()) @db.Uuid
  name         String
  type         TransactionType
  icon         String
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  transactions Transaction[]
  budgets      Budget[]

  @@map("categories")
}

model Transaction {
  id         String          @id @default(uuid()) @db.Uuid
  userId     String          @map("user_id") @db.Uuid
  amount     Decimal         @db.Decimal(10, 2)
  type       TransactionType
  categoryId String          @map("category_id") @db.Uuid
  date       DateTime        @db.Date
  notes      String?         @db.Text
  updatedAt  DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt  DateTime?       @map("deleted_at") @db.Timestamptz

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  // Composite index for efficient sync PULL queries: find all user's changes after a timestamp
  @@index([userId, updatedAt])
  @@map("transactions")
}

model CastleState {
  userId    String   @id @map("user_id") @db.Uuid
  level     Int      @default(1)
  hp        Int      @default(100)
  maxHp     Int      @default(100) @map("max_hp")
  status    String   @default("HEALTHY") // "HEALTHY", "UNDER_ATTACK", "RUINS"
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("castle_states")
}

model Budget {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  categoryId  String   @map("category_id") @db.Uuid
  limitAmount Decimal  @map("limit_amount") @db.Decimal(10, 2)
  period      String   @default("MONTHLY") // "MONTHLY"
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId]) // Solo un presupuesto por categoría por usuario
  @@map("budgets")
}

model GameEventLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  eventDesc String   @map("event_desc") @db.VarChar
  hpImpact  Int      @map("hp_impact")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("game_events_log")
}

model UserWallet {
  userId      String   @id @map("user_id") @db.Uuid
  goldBalance Int      @default(0) @map("gold_balance")
  streakDays  Int      @default(0) @map("streak_days")
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_wallets")
}

model ShopItem {
  id        String          @id @default(uuid()) @db.Uuid
  name      String
  price     Int
  assetUrl  String          @map("asset_url")
  type      String // "WALL", "TOWER", "SKIN", etc.
  inventory UserInventory[]

  @@map("shop_items")
}

model UserInventory {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  itemId     String   @map("item_id") @db.Uuid
  isEquipped Boolean  @default(false) @map("is_equipped")
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  item ShopItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId]) // No tener el mismo item dos veces
  @@map("user_inventories")
}

model UserPushToken {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  tokenString String   @unique @map("token_string")
  deviceInfo  String?  @map("device_info")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_push_tokens")
}

model NotificationLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String
  body      String
  type      String // "ATTACK", "REWARD", "SHOP"
  status    String   @default("SENT") // "SENT", "FAILED"
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("notification_logs")
}
